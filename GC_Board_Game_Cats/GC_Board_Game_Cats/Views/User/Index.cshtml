@model List<GC_Board_Game_Cats.Models.AppUser>

@{
    ViewData["Title"] = "Users";
}

<div class="text-center">
    <h1>Users</h1>
</div>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">Add New User</a>
</div>

@if (Model.Count > 0)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No users yet. <a asp-action="Create">Create one!</a></p>
}
