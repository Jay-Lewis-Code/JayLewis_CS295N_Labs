@model List<GC_Board_Game_Cats.Models.BlogPost>

@{
    ViewData["Title"] = "Blog Page";
}

<h1>Board Game Cats Blog</h1>
<p class="lead">Latest articles, tips, and stories from our community.</p>

<div class="row mt-4">
    <div class="col-md-8">
        <h3>Featured Posts</h3>

        @if (Model != null && Model.Count > 0)
        {
            @foreach (var post in Model)
            {
                <article class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">@post.Title</h5>
                        <p class="card-text">@post.Text</p>
                        <small class="text-muted">
                            By @post.AppUser?.Username |
                            Published: @post.DatePosted.ToString("MMMM dd, yyyy") |
                            Rating: @post.Rating/5
                        </small>
                        <br />
                        <a href="#" class="btn btn-sm btn-outline-primary mt-2">Read More</a>
                    </div>
                </article>
            }
        }
        else
        {
            <p class="text-muted">No blog posts yet. <a asp-action="Create">Create the first one!</a></p>
        }
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Admin Actions</h5>
                <a asp-action="Create" asp-controller="Blog" class="btn btn-sm btn-success w-100">Create New Post</a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Other Pages</h5>
                <ul class="list-unstyled">
                    <li><a asp-action="Index" asp-controller="Home">Home</a></li>
                    <li><a asp-action="AboutAuthor" asp-controller="Blog">About Author</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>